# =============================================================================
# Modèle de secrets - copier vers secrets.yaml puis renseigner les valeurs :
#   cp secrets.yaml.example secrets.yaml
# secrets.yaml est exclu du dépôt par .gitignore.
# =============================================================================

wifi_ssid: "MonWiFi"
wifi_password: "MotDePasseWiFi"

# WiFi de secours (optionnel, à décommenter aussi dans packages/wifi.yaml)
# wifi_ssid2: "AutreReseau"
# wifi_password2: "motdepasse"

# Mot de passe de l'AP de secours
ap_password: "12345678"

# OTA
ota_password: "hem-ota"

# Adresse MAC du BMS JBD (BLE) - ex: "A4:C1:38:12:34:56"
jbd_bms_mac_address: "AA:BB:CC:DD:EE:FF"

# Clé de chiffrement API native ESPHome <-> Home Assistant (requise, api: actif par défaut).
# Générer une clé unique par device (32 octets aléatoires en base64), par ex :
#   python3 -c "import base64, os; print(base64.b64encode(os.urandom(32)).decode())"
# Ne PAS réutiliser la clé d'un autre device.
api_encryption_key: ""

# MQTT (optionnel - seulement si vous décommentez le bloc mqtt: dans
# packages/mqtt.yaml, par ex. pour publier vers un autre système que HA).
# Utiliser une adresse IP ou un hostname pleinement qualifié résolvable
# depuis le conteneur HA (un nom court type "al" peut échouer avec
# "Errno 22 Invalid argument" selon la résolution DNS du conteneur).
# mqtt_broker: "192.168.1.100"
# mqtt_user: "mqtt_user"
# mqtt_password: "mqtt_password"
