# =============================================================================
# Modèle de secrets - copier vers secrets.yaml puis renseigner les valeurs :
#   cp secrets.yaml.example secrets.yaml
# secrets.yaml est exclu du dépôt par .gitignore.
# =============================================================================

wifi_ssid: "MonWiFi"
wifi_password: "MotDePasseWiFi"

# WiFi de secours (optionnel, à décommenter aussi dans packages/wifi.yaml)
# wifi_ssid2: "AutreReseau"
# wifi_password2: "motdepasse"

# Mot de passe de l'AP de secours
ap_password: "12345678"

# MQTT
mqtt_broker: "192.168.1.100"
mqtt_user: "mqtt_user"
mqtt_password: "mqtt_password"

# OTA
ota_password: "hem-ota"

# Adresse MAC du BMS JBD (BLE) - ex: "A4:C1:38:12:34:56"
jbd_bms_mac_address: "AA:BB:CC:DD:EE:FF"

# Clé de chiffrement API native (si activée dans packages/mqtt.yaml)
# Générer une clé : https://esphome.io/components/api.html
# api_encryption_key: ""
